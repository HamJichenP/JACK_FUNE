profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent sharing.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in some cases, you may want to ignore it.
#   https://pipenv.pypa.io/en/latest/advanced/#pipfile-vs-setup-py
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in git.
#   poetry.lock
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in git.
#pdm.lock
#   pdm build directory
.pdm-build/

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

